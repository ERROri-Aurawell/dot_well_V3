NEW A4;
NEW A5;

.strings
"bacana";
"carambolas";

.values 

_C1: 
MOVE %0, A2;
MOVE 1, A1;
CALL;

MOVE 3, A1; 
MOVE 1, A2; 
MOVE _C2, A3;
CALL;

_main:
NEW B1;
MOVE 1, B1; 
MOVE $B1, A2;
MOVE 1, A3; 
MOVE 1, A4; 
MOVE 4, A1;
CALL;
MOVE A5, A2;

MOVE 1, A1; 
CALL;

MOVE 3, A1; 
MOVE _C1, A3; 
CALL;

MOVE 1, A1;
MOVE %1, A2;
CALL;

_C2: 
MOVE 60, A1;
MOVE 0, A2;
CALL;

