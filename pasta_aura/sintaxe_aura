.system //Coisas *do interpretador*
NEW A1; //Tipo da chamada.
NEW A2; //Entrada.
NEW A3; //Entrada secundária.
NEW A4; //Resposta do interpretador.

// 1 - Print
// 2 - Expressão booleana
// 3 - IF TRUE - Execute
// 60 - Para a execussão

.values //Valores do usuário devem aparecer/sumir daqui em tempo de execução
//Eu não vou representar quando o B1 some ou aparece, imagine que no NEW ele surja e no RM ele suma.
//Isso é manipulado pelo interpretador.

_C1: //Funções.
MOVE "bacana", A2;
MOVE 1, A1;
CALL;
MOVE true, A2;
MOVE *D1, A3; //O endereço
MOVE 3, A1;
CALL;

_main:
NEW B1;
MOVE 1, B1;
MOVE "$B1 == 1", A2;
MOVE 2, A1; //2 - checar expressão booleana.
CALL;
MOVE A4, A2;
MOVE 1, A1; //1 - Print.
CALL;

MOVE 3, A1; // IF TRUE.
MOVE _C1, A3; //Aponta o endereço.
//A2 já possui o valor que eu preciso nesse momento.
CALL;

//Aqui só é executado caso o resultado seja falso

*D1: //Ponto de retorno

//O código retorna para cá

MOVE 60, A1;
MOVE 0, A2;
CALL;

